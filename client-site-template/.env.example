# ─── Supabase ────────────────────────────────────────────────────────────────
# Get these from: supabase.com → your project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ─── Client Identity ─────────────────────────────────────────────────────────
# Set this in each Vercel deployment's env vars (different per client)
# It matches the `id` column in the `clients` table
NEXT_PUBLIC_CLIENT_ID=your-client-uuid-here

# ─── Email (Resend) ──────────────────────────────────────────────────────────
# Get from: resend.com → API Keys
# Used for: contact form submissions, password resets
RESEND_API_KEY=re_your-key-here
CONTACT_FORM_TO_EMAIL=client@theirdomain.com

# ─── Site (set per deployment) ───────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://clientsite.com
