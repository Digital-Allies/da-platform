    "innerText": "I Am Local\n\nBased in Kingman, Arizona. Not offshore. Not a chatbot. A real person with a local area code who picks up the phone.",
    "outerHTML": "<div class=\"structural-border bg-bone-white p-8 text-center\">\n                    <div class=\"w-2 h-2 bg-primary-blue rounded-full mx-auto mb-5 brand-pulse\"></div>\n                    <h3 class=\"font-headers font-bold text-base mb-3\" data-en=\"I Am Local\" data-es=\"Soy Local\">I Am Local</h3>\n                    <p class=\"text-xs leading-relaxed\" data-en=\"Based in Kingman, Arizona. Not offshore. Not a chatbot. A real person with a local area code who picks up the phone.\" data-es=\"Con base en Kingman, Arizona. No en el extranjero. No soy un chatbot. Una persona real con código de área local que contesta el teléfono.\">Based in Kingman, Arizona. Not offshore. Not a chatbot. A real person with a local area code who picks up the phone.</p>\n                </div>",
