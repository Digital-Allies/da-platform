{
  "atomicFines": {
    "version": "1.0.0",
    "description": "Atomic Fines CMS Content Schema for Fran & Mabel Rattan Revival Retreat",
    "collections": {
      "products": {
        "description": "Product inventory and catalog items",
        "fields": {
          "id": { "type": "string", "required": true },
          "name": { "type": "string", "required": true },
          "description": { "type": "string", "required": true },
          "category": { "type": "enum", "values": ["seating", "storage", "decor", "mirrors"], "required": true },
          "price": { "type": "number", "required": true },
          "originalPrice": { "type": "number", "required": false },
          "inStock": { "type": "boolean", "default": true },
          "era": { "type": "string", "description": "e.g., 1960s, 1970s, 1980s" },
          "images": { "type": "array", "items": "url", "minItems": 1 },
          "dimensions": {
            "type": "object",
            "fields": {
              "width": { "type": "number" },
              "height": { "type": "number" },
              "depth": { "type": "number" },
              "unit": { "type": "enum", "values": ["in", "cm"] }
            }
          },
          "condition": { "type": "enum", "values": ["excellent", "very-good", "good", "fair"] },
          "featured": { "type": "boolean", "default": false },
          "tags": { "type": "array", "items": "string" }
        }
      },
      "pages": {
        "description": "Editable static pages (About, FAQs, etc.)",
        "fields": {
          "id": { "type": "string", "required": true },
          "slug": { "type": "string", "required": true, "unique": true },
          "title": { "type": "string", "required": true },
          "content": { "type": "richText", "required": true },
          "heroImage": { "type": "url", "required": false },
          "metaDescription": { "type": "string", "maxLength": 160 },
          "published": { "type": "boolean", "default": false },
          "publishedAt": { "type": "date" }
        }
      },
      "blogPosts": {
        "description": "Blog articles and stories",
        "fields": {
          "id": { "type": "string", "required": true },
          "slug": { "type": "string", "required": true, "unique": true },
          "title": { "type": "string", "required": true },
          "excerpt": { "type": "string", "maxLength": 200 },
          "content": { "type": "richText", "required": true },
          "author": { "type": "string", "default": "Fran & Mabel" },
          "featuredImage": { "type": "url" },
          "category": { "type": "string" },
          "tags": { "type": "array", "items": "string" },
          "publishedAt": { "type": "date", "required": true },
          "seoTitle": { "type": "string", "maxLength": 60 },
          "seoDescription": { "type": "string", "maxLength": 160 }
        }
      },
      "settings": {
        "description": "Site-wide configuration",
        "fields": {
          "siteName": { "type": "string", "default": "Atomic Fines" },
          "siteDescription": { "type": "string" },
          "contactEmail": { "type": "email", "required": true },
          "phone": { "type": "string" },
          "socialLinks": {
            "type": "object",
            "fields": {
              "instagram": { "type": "url" },
              "facebook": { "type": "url" },
              "twitter": { "type": "url" }
            }
          },
          "address": {
            "type": "object",
            "fields": {
              "street": { "type": "string" },
              "city": { "type": "string" },
              "state": { "type": "string" },
              "zipCode": { "type": "string" }
            }
          },
          "businessHours": {
            "type": "object",
            "fields": {
              "monday": { "type": "string", "description": "e.g., 10:00 AM - 6:00 PM" },
              "tuesday": { "type": "string" },
              "wednesday": { "type": "string" },
              "thursday": { "type": "string" },
              "friday": { "type": "string" },
              "saturday": { "type": "string" },
              "sunday": { "type": "string" }
            }
          },
          "heroBanner": {
            "type": "object",
            "fields": {
              "title": { "type": "string" },
              "subtitle": { "type": "string" },
              "ctaButtonText": { "type": "string" },
              "ctaButtonLink": { "type": "url" }
            }
          },
          "footerText": { "type": "string" }
        }
      },
      "testimonials": {
        "description": "Customer testimonials and reviews",
        "fields": {
          "id": { "type": "string", "required": true },
          "customerName": { "type": "string", "required": true },
          "content": { "type": "string", "required": true },
          "rating": { "type": "number", "min": 1, "max": 5 },
          "productId": { "type": "string" },
          "image": { "type": "url" },
          "featured": { "type": "boolean", "default": false },
          "dateSubmitted": { "type": "date" }
        }
      }
    },
    "relationships": {
      "products_to_testimonials": {
        "from": "products.id",
        "to": "testimonials.productId",
        "type": "one-to-many"
      }
    },
    "integrations": {
      "digitalAlliesCMS": {
        "endpoint": "https://cms.digitalallies.net/api",
        "auth": "api_key",
        "syncInterval": "hourly",
        "features": ["content_scheduling", "user_roles", "revision_history"]
      },
      "paymentGateway": {
        "stripe": {
          "enabled": true,
          "webhookUrl": "/api/webhooks/stripe"
        }
      },
      "email": {
        "service": "sendgrid",
        "templates": {
          "orderConfirmation": "atomic-fines-order-confirmation",
          "newsletter": "atomic-fines-newsletter"
        }
      }
    }
  }
}
